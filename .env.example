# ── Required ───────────────────────────────
BOT_TOKEN=your_bot_token_here
API_ID=12345678
API_HASH=your_api_hash_here
OWNER_ID=123456789

# ── Optional ───────────────────────────────
# MongoDB connection string (required for user data, captions, thumbnails)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Telegram log channel ID (negative number for channels)
LOG_CHANNEL=-1001234567890

# Admin user IDs (space-separated)
ADMIN=111111111 222222222

# Banned user IDs (space-separated)
BANNED_USERS=

# Bot username (without @)
BOT_USERNAME=YourUploaderBot

# Updates channel username (without @)
UPDATES_CHANNEL=your_channel

# Premium user Pyrogram session string (optional, enables 4 GB uploads)
SESSION_STRING=

# Download chunk size in KB (default: 512)
CHUNK_SIZE=512

# ── yt-dlp cookies (fixes YouTube "Sign in to confirm" error) ──────────────
# Option 1 (recommended for Koyeb): paste the base64-encoded content of your
# cookies.txt file exported from your browser.
#
#   How to export cookies.txt:
#   1. Install "Get cookies.txt LOCALLY" browser extension
#   2. Go to youtube.com while logged in → click the extension → Export
#   3. Run:  base64 -w 0 cookies.txt   (Linux/Mac)
#            [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt"))  (PowerShell)
#   4. Paste the output as the value below
#
YT_COOKIES_B64=

# Option 2 (local/Docker): path to an existing cookies.txt file on disk
COOKIES_FILE=
