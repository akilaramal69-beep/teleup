# ── Required ───────────────────────────────
BOT_TOKEN=your_bot_token_here
API_ID=12345678
API_HASH=your_api_hash_here
OWNER_ID=123456789

# ── Optional ───────────────────────────────
# MongoDB connection string (required for user data, captions, thumbnails)
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Telegram log channel ID (negative number for channels)
LOG_CHANNEL=-1001234567890

# Admin user IDs (space-separated)
ADMIN=111111111 222222222

# Banned user IDs (space-separated)
BANNED_USERS=

# Bot username (without @)
BOT_USERNAME=YourUploaderBot

# Updates channel username (without @)
UPDATES_CHANNEL=your_channel

# Premium user Pyrogram session string (optional, enables 4 GB uploads)
SESSION_STRING=

# Download chunk size in KB (default: 512)
CHUNK_SIZE=512
